# Asterisk SIP
ASTERISK_HOST=192.168.1.100
ASTERISK_PORT=5060
SIP_USERNAME=sipinator
SIP_PASSWORD=your_secure_password_here
SIP_LOCAL_PORT=5080
SIP_EXTENSION=9000

# APNs (Token-basiert)
APNS_KEY_PATH=/certs/AuthKey.p8
APNS_KEY_ID=XXXXXXXXXX
APNS_TEAM_ID=YYYYYYYYYY
APNS_BUNDLE_ID=com.example.sipinator
APNS_USE_SANDBOX=true

# Server
API_SECRET_KEY=change_this_to_a_secure_random_string
DATABASE_PATH=/data/sipinator.db
LOG_LEVEL=INFO
